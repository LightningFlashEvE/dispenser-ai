# ============================================================
# dispenser-ai .gitignore
# ============================================================

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# 虚拟环境
.venv/
venv/
env/
ENV/

# pytest
.pytest_cache/
.coverage
htmlcov/

# mypy / ruff / pyright
.mypy_cache/
.ruff_cache/

# ── 环境变量（含敏感信息，绝不提交）───────────────────────
.env
.env.local
.env.production
# .env.example 保留，供参考

# ── 模型文件（体积巨大，不入仓库）──────────────────────────
models/
*.bin
*.gguf
*.ggml
*.pt
*.pth
*.safetensors
*.onnx

# ── 数据库与运行时数据 ──────────────────────────────────────
data/*.db
data/*.sqlite
data/*.sqlite3
data/logs/
*.log

# ── Node.js / 前端 ──────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# ── IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── 标定与临时文件 ──────────────────────────────────────────
config/calibration*.json
*.tmp
*.bak
