# ============================================================
# backend/.env.example
# 复制为 .env 后填入实际值，.env 不提交 git
# ============================================================

# ── 运行环境 ─────────────────────────────────────────────────
ENV=development           # development | production
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# ── Ollama LLM ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b   # 待选型测试后确定
# 推理完毕后保留模型的秒数：0=立即释放，300=5分钟（半常驻），-1=永久
# 生产建议：300（半常驻），开发建议：300 或 -1（避免冷启动等待）
OLLAMA_KEEP_ALIVE=300

# ── Whisper.cpp ASR ──────────────────────────────────────────
WHISPER_CPP_MODEL_PATH=models/whisper/ggml-small.bin

# ── MeloTTS ──────────────────────────────────────────────────
MELOTTS_MODEL_PATH=models/melotts

# ── 数据库 ───────────────────────────────────────────────────
SQLITE_DB_PATH=data/app.db

# ── 规则引擎配置 ─────────────────────────────────────────────
RULES_CONFIG_PATH=config/rules.json
INTENT_SCHEMA_PATH=../shared/intent_schema.json
COMMAND_SCHEMA_PATH=../shared/command_schema.json

# 天平量程上限（mg），默认 220g = 220000mg，与 WKC204C 规格一致
BALANCE_MAX_MASS_MG=220000

# ── C++ 后级控制程序 TCP 连接 ────────────────────────────────
CONTROL_ADAPTER_HOST=localhost
CONTROL_ADAPTER_PORT=9000

# ── 天平串口（梅特勒 WKC204C，RS422-USB）────────────────────
BALANCE_SERIAL_PORT=/dev/ttyUSB0   # Jetson 上实际设备路径
BALANCE_BAUD_RATE=9600

# ── 音频设备 ─────────────────────────────────────────────────
AUDIO_DEVICE_INDEX=0      # sounddevice 设备索引，0=系统默认麦克风

# ── 摄像头 ───────────────────────────────────────────────────
CAMERA_DEVICE_INDEX=0     # OpenCV VideoCapture 索引

# ── 业务规则 ─────────────────────────────────────────────────
# 是否跳过用户确认（仅开发/调试阶段使用，生产必须为 false）
SKIP_CONFIRMATION=false

# 默认称量容差（mg），当用户未指定时，规则引擎使用此值
# 实际值 = max(DEFAULT_TOLERANCE_MG, target_mass_mg * DEFAULT_TOLERANCE_PCT / 100)
DEFAULT_TOLERANCE_MG=10
DEFAULT_TOLERANCE_PCT=2.0

# ── 对话状态（内存模式） ──────────────────────────────────────
# 单次对话最大补槽轮数，超出后重置并提示用户重新开始
DIALOG_MAX_ROUNDS=8
