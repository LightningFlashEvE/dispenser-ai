# ============================================================
# backend/.env.example
# 复制为 .env 后填入实际值，.env 不提交 git
#
# ── 部署目标：英伟达 Jetson Orin NX Super 16GB + 512GB NVMe
# ── 当前开发：llama.cpp server + mock-qt
# ============================================================

# ── 运行环境 ─────────────────────────────────────────────────
ENV=development           # development | production
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# ── LLM (llama.cpp server) ─────────────────────────────────
# 当前使用 Qwen3-4B-Q5_K_M，显存约 3GB。模型文件放 models/Qwen/ 下
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL_PATH=models/Qwen/Qwen3-4B-Q5_K_M.gguf
LLM_CONTEXT_LENGTH=16384
LLM_MAX_TOKENS=768
# 对话阶段（自然语言）使用较高温度以获得自然回答
LLM_DIALOG_TEMPERATURE=0.6
# 意图阶段（force_json=True）使用极低温度以提升 JSON 稳定性
LLM_INTENT_TEMPERATURE=0.05
LLM_GP_LAYERS=99
LLM_THREADS=6

# ── Whisper.cpp ASR ──────────────────────────────────────────
WHISPER_SERVER_URL=http://127.0.0.1:8081
# 推荐 small 模型（准确率优于 base，在 Jetson CUDA 下延迟 < 500ms）
WHISPER_CPP_MODEL_PATH=models/whisper/ggml-small.bin
WHISPER_LANGUAGE=zh
WHISPER_VAD_THRESHOLD=0.5
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_SIZE_MS=100
AUDIO_MAX_BUFFER_MS=30000

# ── TTS 本地服务 (MeloTTS) ─────────────────────────────────
TTS_PROVIDER=melotts
TTS_BASE_URL=http://127.0.0.1:8020
TTS_TIMEOUT_SEC=60
TTS_PLAY_DEFAULT=true

# ── 数据库 ───────────────────────────────────────────────────
SQLITE_DB_PATH=data/app.db

# ── 规则引擎与 Schema ────────────────────────────────────────
RULES_CONFIG_PATH=config/rules.json
INTENT_SCHEMA_PATH=../shared/intent_schema.json
COMMAND_SCHEMA_PATH=../shared/command_schema.json

# 天平量程上限（mg），默认 220g = 220000mg，与 WKC204C 规格一致
BALANCE_MAX_MASS_MG=220000

# ── C++ 后级控制程序 TCP 连接 ────────────────────────────────
CONTROL_ADAPTER_HOST=localhost
CONTROL_ADAPTER_PORT=9000

# ── 天平串口（梅特勒 WKC204C，RS422-USB）────────────────────
BALANCE_SERIAL_PORT=/dev/ttyUSB0
BALANCE_BAUD_RATE=9600

# ── 音频 / 摄像头设备 ────────────────────────────────────────
AUDIO_DEVICE_INDEX=0
CAMERA_DEVICE_INDEX=0

# ── 业务规则 ─────────────────────────────────────────────────
# 是否跳过用户确认（仅开发/调试阶段使用，生产必须为 false）
SKIP_CONFIRMATION=false

# 默认称量容差（mg）
DEFAULT_TOLERANCE_MG=10
DEFAULT_TOLERANCE_PCT=2.0

# ── 对话状态 ─────────────────────────────────────────────────
DIALOG_MAX_ROUNDS=8
# AI 生成 pending_intent 后，用户确认的有效期（秒）。超时自动清除。
PENDING_INTENT_TTL_SEC=60

# ── CORS ─────────────────────────────────────────────────────
# 允许访问后端的 origin 列表，逗号分隔。生产部署时加入局域网实际 IP。
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.10.175:5173
